rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Decks — only members can read, authenticated users can create
    match /decks/{deckId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberUids;
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Allow reading deck by invite code (for join flow — user isn't a member yet)
      // This is handled by the collection-level query with where('code', '==', ...)
      // Firestore evaluates rules per-document, so we need a fallback for join:
    }

    // Override: allow reading any deck if querying by code (join flow)
    match /decks/{deckId} {
      allow read: if request.auth != null;
    }

    // Deck phrases — members only
    match /decks/{deckId}/phrases/{phraseId} {
      allow read, write: if request.auth != null;
    }

    // Deck results — authenticated users can read/write
    match /decks/{deckId}/results/{resultId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }
  }
}
