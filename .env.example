# Firebase Configuration — copy this to .env.local and fill in your values
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google AdSense — get these from https://adsense.google.com
# Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_CLIENT=
# Ad unit IDs — create these in AdSense → Ads → By ad unit
VITE_AD_SLOT_BANNER=
VITE_AD_SLOT_INTERSTITIAL=
